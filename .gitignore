# =============================================================================
# .gitignore — common-cornershop
# NX Monorepo | TypeScript | Node.js | Fastify | TypeORM | PostgreSQL | Jest
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# Per-project build output inside NX apps/libs
apps/*/dist/
libs/*/dist/

# Temporary NX output file (generated by nx commands, not meant to be committed)
output.json

# -----------------------------------------------------------------------------
# NX Cache & Metadata
# -----------------------------------------------------------------------------
.nx/cache
.nx/workspace-data
output.json

# -----------------------------------------------------------------------------
# Environment Variables & Secrets
# IMPORTANT: .env.example is intentionally NOT ignored — it is a safe template.
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

# -----------------------------------------------------------------------------
# Test Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
lcov.info
*.lcov

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Runtime / Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# IDEs & Editors
# VS Code workspace settings are personal; share extensions.json if needed.
# JetBrains IDE metadata is machine-specific.
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# Linux
*~

# -----------------------------------------------------------------------------
# Docker (local overrides only — docker-compose.yml IS versioned)
# -----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# TypeORM Migrations (generated artifacts — keep only hand-crafted ones)
# Uncomment the line below if you auto-generate migrations and commit them.
# Otherwise, leave commented so generated migration files are tracked.
# -----------------------------------------------------------------------------
# **/migrations/*.generated.ts

# -----------------------------------------------------------------------------
# Security — Credentials & Sensitive Files
# These should NEVER be committed regardless of .env coverage.
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
*.jks
*.keystore

# Local database dumps (may contain sensitive data)
*.sql
*.dump
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tgz
*.tar.gz
.cache/
