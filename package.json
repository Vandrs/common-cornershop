{
  "name": "common-cornershop",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start:dev": "nx serve api",
    "build": "nx build api",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write \"**/*.ts\"",
    "test": "nx run-many --target=test --all",
    "test:unit": "nx run-many --target=test --all --testPathPattern=src",
    "test:integration": "nx run-many --target=test --all --testPathPattern=integration",
    "test:e2e": "nx run-many --target=test --all --testPathPattern=e2e-spec",
    "test:watch": "nx run-many --target=test --all --watch",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "migration:generate": "nx run api:migration:generate",
    "migration:run": "nx run api:migration:run",
    "migration:revert": "nx run api:migration:revert",
    "seed": "nx run api:seed",
    "prepare": "husky"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@nx/eslint": "^18.3.5",
    "@nx/eslint-plugin": "^18.3.5",
    "@nx/jest": "^18.3.5",
    "@nx/js": "^18.3.5",
    "@nx/node": "^18.3.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.31",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "nx": "^18.3.5",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
