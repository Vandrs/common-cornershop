NODE_ENV=development
PORT=3000

# Application database connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cornershop
DB_NAME_TEST=cornershop_test

# Set to "true" to enable TLS for the database connection (recommended in production)
DB_SSL=false

# Set to "false" only when using managed databases with self-signed certificates.
# Defaults to "true" to enforce certificate validation and prevent MITM attacks.
DB_SSL_REJECT_UNAUTHORIZED=true

# PostgreSQL container credentials (used by docker-compose)
POSTGRES_DB=cornershop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
